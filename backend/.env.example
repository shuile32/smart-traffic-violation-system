# 数据库
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/traffic_violation

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# LLM — 智谱 GLM（OpenAI 兼容接口）
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_API_KEY=your-zhipu-api-key
LLM_MODEL=glm-4-flash

# 邮件 SMTP
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your-email@qq.com
SMTP_PASSWORD=your-smtp-auth-code
SMTP_FROM=noreply@traffic-violation.local

# 文件存储
MEDIA_STORAGE_DIR=./media
